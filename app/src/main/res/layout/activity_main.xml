<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:keepScreenOn="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical" >

        <com.pierfrancescosoffritti.androidyoutubeplayer.core.player.views.YouTubePlayerView
            android:id="@+id/youtube_player_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
        />

        <RadioGroup
            android:id="@+id/radio_play_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:checkedButton="@+id/radio_play_music">

            <RadioButton
                android:id="@+id/radio_play_music"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Spill musikk" />

            <RadioButton
                android:id="@+id/radio_play_video"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Spill video" />
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="300dp"
            android:layout_gravity="center"
            android:gravity="center"
            android:textSize="18pt"
            android:text="Scan NFC brikke\n for å starte avspilling" />
        <TextView
            android:id="@+id/text_status"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:gravity="end"
            android:textSize="10pt"
            android:text="Disconnected" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>